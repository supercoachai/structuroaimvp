{
  "buildCommand": "bash build.sh",
  "outputDirectory": ".",
  "redirects": [
    {
      "source": "/waitlist",
      "destination": "/wachtlijst/",
      "permanent": false
    },
    {
      "source": "/waitlist/",
      "destination": "/wachtlijst/",
      "permanent": false
    },
    {
      "source": "/inschrijven",
      "destination": "/wachtlijst/",
      "permanent": false
    },
    {
      "source": "/inschrijven/",
      "destination": "/wachtlijst/",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/wachtlijst",
      "destination": "/wachtlijst/index.html"
    },
    {
      "source": "/cyclus",
      "destination": "/cyclus/index.html"
    },
    {
      "source": "/ph/static/:path*",
      "destination": "https://eu-assets.i.posthog.com/static/:path*"
    },
    {
      "source": "/ph/:path*",
      "destination": "https://eu.i.posthog.com/:path*"
    }
  ]
}
