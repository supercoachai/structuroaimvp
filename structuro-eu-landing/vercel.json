{
  "buildCommand": "bash build.sh",
  "outputDirectory": ".",
  "headers": [
    {
      "source": "/uploads/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/js/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, stale-while-revalidate=604800"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/waitlist",
      "destination": "https://www.structuro.ai/registreren",
      "permanent": false
    },
    {
      "source": "/waitlist/",
      "destination": "https://www.structuro.ai/registreren",
      "permanent": false
    },
    {
      "source": "/inschrijven",
      "destination": "https://www.structuro.ai/registreren",
      "permanent": false
    },
    {
      "source": "/inschrijven/",
      "destination": "https://www.structuro.ai/registreren",
      "permanent": false
    },
    {
      "source": "/wachtlijst",
      "destination": "https://www.structuro.ai/registreren",
      "permanent": false
    },
    {
      "source": "/wachtlijst/",
      "destination": "https://www.structuro.ai/registreren",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/cyclus",
      "destination": "/cyclus/index.html"
    },
    {
      "source": "/ph/static/:path*",
      "destination": "https://eu-assets.i.posthog.com/static/:path*"
    },
    {
      "source": "/ph/:path*",
      "destination": "https://eu.i.posthog.com/:path*"
    }
  ]
}
