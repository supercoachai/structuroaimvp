{
  "buildCommand": "bash build.sh",
  "outputDirectory": ".",
  "headers": [
    {
      "source": "/uploads/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/js/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=604800, stale-while-revalidate=86400"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "structuro.eu" }],
      "destination": "https://www.structuro.eu/:path*",
      "permanent": true
    },
    {
      "source": "/waitlist",
      "destination": "https://www.structuro.ai/registreren",
      "permanent": false
    },
    {
      "source": "/waitlist/",
      "destination": "https://www.structuro.ai/registreren",
      "permanent": false
    },
    {
      "source": "/inschrijven",
      "destination": "https://www.structuro.ai/registreren",
      "permanent": false
    },
    {
      "source": "/inschrijven/",
      "destination": "https://www.structuro.ai/registreren",
      "permanent": false
    },
    {
      "source": "/wachtlijst",
      "destination": "https://www.structuro.ai/registreren",
      "permanent": false
    },
    {
      "source": "/wachtlijst/",
      "destination": "https://www.structuro.ai/registreren",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/cyclus",
      "destination": "/cyclus/index.html"
    },
    {
      "source": "/ph/static/:path(.*)",
      "destination": "https://eu-assets.i.posthog.com/static/:path"
    },
    {
      "source": "/ph/array/:path(.*)",
      "destination": "https://eu-assets.i.posthog.com/array/:path"
    },
    {
      "source": "/ph/:path(.*)",
      "destination": "https://eu.i.posthog.com/:path"
    }
  ]
}
