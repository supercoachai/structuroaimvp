{
  "name": "structuroai-mvp",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0 <=24.x"
  },
  "scripts": {
    "clean": "rm -rf .next",
    "clean:all": "rm -rf .next node_modules/.cache",
    "free:3000": "sh -c 'lsof -ti :3000 | xargs kill -9 2>/dev/null || true'",
    "dev": "npm run free:3000 && next dev -p 3000",
    "dev:clean": "npm run free:3000 && npm run clean && next dev -p 3000",
    "dev:fresh": "npm run free:3000 && npm run clean:all && next dev -p 3000",
    "dev:turbo": "npm run free:3000 && next dev --turbo -p 3000",
    "dev:3001": "next dev -p 3001",
    "prebuild": "npm run clean",
    "build": "next build",
    "start": "npm run free:3000 && next start",
    "start:prod": "npm run build && npm run start",
    "lint": "next lint",
    "test:task-put": "npx --yes tsx src/lib/buildTaskPutDbUpdates.test.ts",
    "test:focus-events": "npx --yes tsx src/lib/posthog/focusSessionEvents.test.ts",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:status": "supabase status",
    "supabase:reset": "supabase db reset",
    "posthog:wizard:ci": "bash scripts/run-posthog-wizard-ci.sh",
    "smoke:preview": "node scripts/launch-smoke-preview.mjs"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@opentelemetry/api-logs": "^0.217.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.217.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-logs": "^0.217.0",
    "@posthog/nextjs-config": "^1.7.6",
    "@supabase/ssr": "^0.7.0",
    "@supabase/supabase-js": "^2.83.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "canvas-confetti": "^1.9.4",
    "lucide-react": "^0.511.0",
    "next": "15.5.12",
    "posthog-js": "^1.372.10",
    "posthog-node": "^5.21.2",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "stripe": "^17.7.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@next/bundle-analyzer": "^16.2.4",
    "@tailwindcss/postcss": "^4",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.5.12",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
